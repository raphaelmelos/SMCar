CREATE DATABASE IF NOT EXISTS SMCar;
USE `SMCar` ;

CREATE TABLE IF NOT EXISTS `SMCar`.`Veiculos` (
  `id_Veiculos` INT NOT NULL AUTO_INCREMENT,
  `Home` TINYINT NULL,
  `Ano` INT NULL,
  `Kms` INT NULL,
  `Cambio` VARCHAR(45) NULL,
  `Descricao` MEDIUMTEXT NULL,
  `Foto` VARCHAR(255) NULL,
  `Cor` VARCHAR(45) NULL,
  `Carroceria` VARCHAR(45) NULL,
  `Preco` INT NULL,
  `Em_Estoque` TINYINT NULL,
  `Marca` VARCHAR(45) NULL,
  `Destaque` TINYINT NULL,
  PRIMARY KEY (`id_Veiculos`))
ENGINE = InnoDB;

CREATE TABLE IF NOT EXISTS `SMCar`.`Estoque` (
  `id_Estoque` INT NOT NULL AUTO_INCREMENT,
  `Descricao` MEDIUMTEXT NULL,
  `Preco` INT NULL,
  PRIMARY KEY (`id_Estoque`))
ENGINE = InnoDB;

CREATE TABLE IF NOT EXISTS `SMCar`.`Veiculos_Estoque` (
  `id_Estoque` INT NULL,
  `id_Veiculos` INT NULL,
  `Id` INT NOT NULL AUTO_INCREMENT,
  INDEX `FK_Veiculos_VeiculosEstoque` (`id_Veiculos` ASC) ,
  INDEX `FK_Estoque_VeiculosEstoque` (`id_Estoque` ASC) ,
  PRIMARY KEY (`Id`),
  UNIQUE INDEX `UQ_VeiculosEstoque` (`id_Veiculos` ASC, `id_Estoque` ASC) ,
  CONSTRAINT `FK_Veiculos_VeiculosEstoque`
    FOREIGN KEY (`id_Veiculos`)
    REFERENCES `SMCar`.`Veiculos` (`id_Veiculos`)
    ON DELETE NO ACTION
    ON UPDATE NO ACTION,
  CONSTRAINT `FK_Estoque_VeiculosEstoque`
    FOREIGN KEY (`id_Estoque`)
    REFERENCES `SMCar`.`Estoque` (`id_Estoque`)
    ON DELETE NO ACTION
    ON UPDATE NO ACTION)
ENGINE = InnoDB;


#Select para teste de relacionamento
SELECT 
    v.id_Veiculos,
    v.Marca,
    v.Ano,
    e.Descricao AS Item,
    e.Preco AS Preco_Item
FROM Veiculos v
JOIN Veiculos_Estoque ve ON v.id_Veiculos = ve.id_Veiculos
JOIN Estoque e ON ve.id_Estoque = e.id_Estoque;


#Select quase pra mesma coisa do de cima, mas esse aqui tem uma restrição "WHERE"
SELECT 
    v.Marca,
    v.Ano,
    e.Descricao
FROM Veiculos v
JOIN Veiculos_Estoque ve ON v.id_Veiculos = ve.id_Veiculos
JOIN Estoque e ON ve.id_Estoque = e.id_Estoque
WHERE v.id_Veiculos = 1;


#Select que verificaquantos itens cada veiculo tem
SELECT 
    v.id_Veiculos,
    v.Marca,
    COUNT(ve.id_Estoque) AS Total_Itens
FROM Veiculos v
LEFT JOIN Veiculos_Estoque ve ON v.id_Veiculos = ve.id_Veiculos
GROUP BY v.id_Veiculos, v.Marca;